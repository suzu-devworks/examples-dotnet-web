{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff ",
        "ColorBehavior": "Enabled"
      }
    }
  },
  "AllowedHosts": "*",
  "Demo": {
    "Source": {
      "AppSettings": "Defined in appsettings.json"
    },
    "OrderProbe": {
      "All": "appsettings.json",
      "ConfigurePattern": "appsettings.json",
      "UsePattern": "appsettings.json"
    },
    "Compare": {
      "ConfigureVsAppSettings": "From appsettings.json",
      "UseVsAppSettings": "From appsettings.json",
      "ConfigureVsProgramConfigManager": "From appsettings.json",
      "UseVsProgramConfigManager": "From appsettings.json"
    }
  }
}